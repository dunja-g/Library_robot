# Run the web app without hardware. Set to false on the Raspberry Pi robot.
LIBRARY_ROBOT_USE_MOCK=true
LIBRARY_ROBOT_SERIAL_PORT=/dev/ttyACM0

# Camera and control loop
LIBRARY_ROBOT_CAMERA_WIDTH=640
LIBRARY_ROBOT_CAMERA_HEIGHT=480
LIBRARY_ROBOT_CAMERA_FPS=20
LIBRARY_ROBOT_CONTROL_HZ=10

# Navigation tuning
LIBRARY_ROBOT_ALIGN_TOLERANCE_PX=30
LIBRARY_ROBOT_STOP_DISTANCE_CM=25
LIBRARY_ROBOT_OBSTACLE_DISTANCE_CM=20
LIBRARY_ROBOT_SCAN_TIMEOUT_SECONDS=60
LIBRARY_ROBOT_TARGET_CONFIRMATION_FRAMES=2
LIBRARY_ROBOT_ALIGNMENT_CONFIRMATION_FRAMES=2
LIBRARY_ROBOT_TARGET_LOSS_TOLERANCE_FRAMES=3
LIBRARY_ROBOT_MIN_MARKER_AREA_PX=0
