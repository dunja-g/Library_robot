# Run the web app without hardware. Set to false on the Raspberry Pi robot.
LIBRARY_ROBOT_USE_MOCK=true
LIBRARY_ROBOT_SERIAL_PORT=/dev/ttyACM0
# aruco = marker route, grid = marker-free 1A-4B encoder route
LIBRARY_ROBOT_NAVIGATION_MODE=aruco

# Camera and control loop
LIBRARY_ROBOT_CAMERA_WIDTH=640
LIBRARY_ROBOT_CAMERA_HEIGHT=480
LIBRARY_ROBOT_CAMERA_FPS=20
LIBRARY_ROBOT_CONTROL_HZ=10

# Navigation tuning
LIBRARY_ROBOT_ALIGN_TOLERANCE_PX=30
LIBRARY_ROBOT_STOP_DISTANCE_CM=35
LIBRARY_ROBOT_OBSTACLE_DISTANCE_CM=20
LIBRARY_ROBOT_SCAN_TIMEOUT_SECONDS=60
LIBRARY_ROBOT_TARGET_CONFIRMATION_FRAMES=2
LIBRARY_ROBOT_ALIGNMENT_CONFIRMATION_FRAMES=2
LIBRARY_ROBOT_TARGET_LOSS_TOLERANCE_FRAMES=3
LIBRARY_ROBOT_MIN_MARKER_AREA_PX=0
LIBRARY_ROBOT_TURN_90_SECONDS=0.8
LIBRARY_ROBOT_UTURN_SECONDS=1.6
LIBRARY_ROBOT_DESTINATION_DWELL_SECONDS=5
LIBRARY_ROBOT_AUTO_RETURN=true

# Fixed-grid encoder mode. Leave dimensions blank until measured.
LIBRARY_ROBOT_GRID_FIRST_ROW_CM=
LIBRARY_ROBOT_GRID_ROW_SPACING_CM=
LIBRARY_ROBOT_GRID_APPROACH_CM=
LIBRARY_ROBOT_ENCODER_TICKS_PER_CM=
LIBRARY_ROBOT_ENCODER_TICKS_PER_REV=4
LIBRARY_ROBOT_WHEEL_DIAMETER_CM=6.5
LIBRARY_ROBOT_ENCODER_TURN_90_TICKS=
LIBRARY_ROBOT_ENCODER_TURN_180_TICKS=
LIBRARY_ROBOT_ENCODER_STALL_SECONDS=2
LIBRARY_ROBOT_GRID_TURN_SOURCE=imu
